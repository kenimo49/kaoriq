---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'ja')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<BaseLayout
  title="KaoriQ — あなたの性格に合う香りを、データで見つける"
  description="59,000本以上の香水データベースとAI性格診断で、あなたに本当に似合う香りを提案します。"
  lang="ja"
  ogUrl="https://kaoriq.com/ja/"
  ogDescription="59,000本以上の香水データベースとAI性格診断で、あなたに本当に似合う香りを提案します。"
>
  <Nav lang="ja" current="home" />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <section style="margin-bottom: 3rem;">
      <h1 style="font-size: 2.25rem; font-weight: 700; line-height: 1.3; margin-bottom: 1rem;">
        あなたの性格が、<br />香りを選ぶ。
      </h1>
      <p style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; max-width: 560px;">
        KaoriQは59,000本以上の香水データベースとAI性格診断を組み合わせ、あなたに似合う香りを提案します。直感でも流行でもなく、データに基づいた香り選び。
      </p>
    </section>

    <section style="margin-bottom: 3rem;">
      <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--text-label);">Coming Soon</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div style="padding: 1.25rem; border: 1px solid var(--text-separator); border-radius: 12px; background: var(--bg-card);">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
            <span style="font-size: 1.25rem;">🧠</span>
            <h3 style="font-size: 1rem; font-weight: 600; margin: 0;">AI 香りマッチング</h3>
          </div>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0; line-height: 1.6;">
            59,000本以上の香水データベースとBig Five性格診断を組み合わせた、チャット型の香りアドバイザー。会話しながら、あなたに合う香りを見つけます。
          </p>
        </div>
        <div style="padding: 1.25rem; border: 1px solid var(--text-separator); border-radius: 12px; background: var(--bg-card);">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
            <span style="font-size: 1.25rem;">🛍️</span>
            <h3 style="font-size: 1rem; font-weight: 600; margin: 0;">香り雑貨ショップ</h3>
          </div>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0; line-height: 1.6;">
            キャンドル、ディフューザー、お香など、あなたの性格タイプに合わせて厳選した空間フレグランスのコレクション。
          </p>
        </div>
      </div>
    </section>

    {posts.length > 0 && (
      <section>
        <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1.5rem; color: var(--text-label);">最新の記事</h2>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {posts.map(post => (
            <a href={`/ja/blog/${post.id.replace('ja/', '')}/`} style="text-decoration: none; color: inherit;">
              <article style="padding: 1rem 0; border-bottom: 1px solid var(--text-separator);">
                <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.35rem;">{post.data.title}</h3>
                <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">
                  <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().split('T')[0]}</time>
                  {' — '}{post.data.description}
                </p>
              </article>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
