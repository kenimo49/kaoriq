---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(p => p.data.lang === 'ko');
  return posts.map(post => ({
    params: { slug: post.id.replace('ko/', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonicalUrl = `https://kaoriq.com/ko/blog/${post.id.replace('ko/', '')}`;
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  lang="ko"
  date={post.data.date}
  category={post.data.category}
  tags={post.data.tags}
  canonicalUrl={canonicalUrl}
  ogImage={post.data.og_image}
  crossPostedTo={post.data.cross_posted_to}
>
  <Content />
</BlogLayout>
