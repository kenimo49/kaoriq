---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import { getCollection } from 'astro:content';
import { staticAlternates } from '../../../lib/alternates';

export async function getStaticPaths() {
  return [
    { params: { category: 'guide' } },
    { params: { category: 'science' } },
    { params: { category: 'story' } },
  ];
}

const { category } = Astro.params;

const labels: Record<string, { title: string; description: string }> = {
  guide: {
    title: 'Guides — KaoriQ',
    description: 'Practical guides for choosing home fragrance: candles, diffusers, incense, room sizes, layering, and rotation.',
  },
  science: {
    title: 'Science — KaoriQ',
    description: 'The science of scent: olfactory neuroscience, Big Five personality and fragrance preferences, ingredient chemistry.',
  },
  story: {
    title: 'Story — KaoriQ',
    description: 'Stories behind fragrance materials: orris, sandalwood, vetiver, lavender, kodo and more.',
  },
};

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'en' && p.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const meta = labels[category!];

const alternates = staticAlternates({
  en: `/blog/category/${category}/`,
  ja: `/ja/blog/category/${category}/`,
});
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  lang="en"
  ogUrl={`https://kaoriq.com/blog/category/${category}/`}
  ogDescription={meta.description}
  alternates={alternates}
>
  <Nav lang="en" current="blog" />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">
      <a href="/blog/" style="color: inherit;">&larr; All articles</a>
    </p>
    <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem; text-transform: capitalize;">{category}</h1>
    <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem;">{meta.description}</p>

    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
      {posts.map(post => (
        <a href={`/blog/${post.id.replace('en/', '')}/`} style="text-decoration: none; color: inherit;">
          <article style="padding: 1rem 0; border-bottom: 1px solid var(--text-separator);">
            <h2 style="font-size: 1.1rem; font-weight: 600; margin: 0 0 0.35rem;">{post.data.title}</h2>
            <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">
              <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().split('T')[0]}</time>
              {' — '}{post.data.description}
            </p>
          </article>
        </a>
      ))}
      {posts.length === 0 && (
        <p style="color: var(--text-muted);">No articles in this category yet.</p>
      )}
    </div>
  </main>
</BaseLayout>
