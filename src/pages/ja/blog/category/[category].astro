---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Nav from '../../../../components/Nav.astro';
import { getCollection } from 'astro:content';
import { staticAlternates } from '../../../../lib/alternates';

export async function getStaticPaths() {
  return [
    { params: { category: 'guide' } },
    { params: { category: 'science' } },
    { params: { category: 'story' } },
  ];
}

const { category } = Astro.params;

const labels: Record<string, { title: string; description: string; label: string }> = {
  guide: {
    title: '選び方ガイド — KaoriQ',
    label: '選び方ガイド',
    description: 'キャンドル・ディフューザー・お香の選び方、部屋サイズ別の使い分け、レイヤリング、ローテーションなど、空間フレグランスの実用ガイド。',
  },
  science: {
    title: '香りの科学 — KaoriQ',
    label: '香りの科学',
    description: '嗅覚神経科学、Big Five性格と香りの好みの関係、香料成分の化学。香りを「なぜ」で読み解きます。',
  },
  story: {
    title: '香りの世界 — KaoriQ',
    label: '香りの世界',
    description: 'オリス、サンダルウッド、ベチバー、ラベンダー、香道など、香り素材の文化と歴史を辿るストーリー。',
  },
};

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'ja' && p.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const meta = labels[category!];

const alternates = staticAlternates({
  en: `/blog/category/${category}/`,
  ja: `/ja/blog/category/${category}/`,
});
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  lang="ja"
  ogUrl={`https://kaoriq.com/ja/blog/category/${category}/`}
  ogDescription={meta.description}
  alternates={alternates}
>
  <Nav lang="ja" current="blog" />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">
      <a href="/ja/blog/" style="color: inherit;">&larr; すべての記事</a>
    </p>
    <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;">{meta.label}</h1>
    <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem;">{meta.description}</p>

    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
      {posts.map(post => (
        <a href={`/ja/blog/${post.id.replace('ja/', '')}/`} style="text-decoration: none; color: inherit;">
          <article style="padding: 1rem 0; border-bottom: 1px solid var(--text-separator);">
            <h2 style="font-size: 1.1rem; font-weight: 600; margin: 0 0 0.35rem;">{post.data.title}</h2>
            <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">
              <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().split('T')[0]}</time>
              {' — '}{post.data.description}
            </p>
          </article>
        </a>
      ))}
      {posts.length === 0 && (
        <p style="color: var(--text-muted);">このカテゴリの記事はまだありません。</p>
      )}
    </div>
  </main>
</BaseLayout>
