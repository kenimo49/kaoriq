---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import { staticAlternates } from '../lib/alternates';

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'en')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const alternates = staticAlternates({ en: '/', ja: '/ja/' });
---

<BaseLayout
  title="KaoriQ — Data-Driven Fragrance Recommendations"
  description="Discover your perfect scent through personality-based AI recommendations, backed by a database of 59,000+ fragrances."
  lang="en"
  ogUrl="https://kaoriq.com/"
  ogDescription="Discover your perfect scent through personality-based AI recommendations."
  alternates={alternates}
  isHome
>
  <Nav lang="en" current="home" />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <section style="margin-bottom: 3rem;">
      <h1 style="font-size: 2.25rem; font-weight: 700; line-height: 1.3; margin-bottom: 1rem;">
        Your personality.<br />Your scent.
      </h1>
      <p style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; max-width: 560px;">
        KaoriQ matches fragrances to your personality using AI and a database of 59,000+ scents. No guesswork, no hype — just the science of what smells right on you.
      </p>
    </section>

    <section style="margin-bottom: 3rem;">
      <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--text-label);">Coming Soon</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <a href="/blog/why-personality-matters-for-fragrance/" class="soon-card">
          <div class="soon-card-head">
            <span style="font-size: 1.25rem;">🧠</span>
            <h3 style="font-size: 1rem; font-weight: 600; margin: 0;">AI Scent Matching</h3>
            <span class="soon-cta">Read the thesis &rarr;</span>
          </div>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0; line-height: 1.6;">
            A chat-based fragrance advisor that combines our 59,000+ fragrance database with Big Five personality diagnostics to find your perfect scent. Until it ships, read why personality predicts fragrance preferences.
          </p>
        </a>
        <a href="/blog/" class="soon-card">
          <div class="soon-card-head">
            <span style="font-size: 1.25rem;">🛍️</span>
            <h3 style="font-size: 1rem; font-weight: 600; margin: 0;">Fragrance Shop</h3>
            <span class="soon-cta">Browse the guides &rarr;</span>
          </div>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0; line-height: 1.6;">
            Curated home fragrance collection — candles, diffusers, and incense selected to match your personality type. While we build it, our guides walk you through what to buy and why.
          </p>
        </a>
      </div>
    </section>

    {posts.length > 0 && (
      <section>
        <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1.5rem; color: var(--text-label);">Latest Articles</h2>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {posts.map(post => (
            <a href={`/blog/${post.id.replace('en/', '')}/`} style="text-decoration: none; color: inherit;">
              <article style="padding: 1rem 0; border-bottom: 1px solid var(--text-separator);">
                <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.35rem;">{post.data.title}</h3>
                <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">
                  <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().split('T')[0]}</time>
                  {' — '}{post.data.description}
                </p>
              </article>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .soon-card {
    padding: 1.25rem;
    border: 1px solid var(--text-separator);
    border-radius: 12px;
    background: var(--bg-card);
    display: block;
    color: inherit !important;
    text-decoration: none !important;
    transition: border-color 0.15s, transform 0.15s;
  }
  .soon-card:hover {
    border-color: var(--accent-primary);
  }
  .soon-card-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .soon-cta {
    margin-left: auto;
    font-size: 0.78rem;
    color: var(--accent-primary);
    letter-spacing: 0.04em;
  }
  @media (max-width: 480px) {
    .soon-cta { display: none; }
  }
</style>
