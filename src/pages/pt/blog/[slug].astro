---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { blogAlternates } from '../../../lib/alternates';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const posts = allPosts.filter(p => p.data.lang === 'pt');
  return posts.map(post => {
    const slug = post.id.replace('pt/', '');
    return {
      params: { slug },
      props: { post, alternates: blogAlternates(allPosts, slug) },
    };
  });
}

const { post, alternates } = Astro.props;
const { Content } = await render(post);
const canonicalUrl = `https://kaoriq.com/pt/blog/${post.id.replace('pt/', '')}/`;
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  lang="pt"
  date={post.data.date}
  updated={post.data.updated}
  category={post.data.category}
  tags={post.data.tags}
  canonicalUrl={canonicalUrl}
  ogImage={post.data.og_image}
  crossPostedTo={post.data.cross_posted_to}
  alternates={alternates}
>
  <Content />
</BlogLayout>
