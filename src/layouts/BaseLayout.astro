---
interface Props {
  title: string;
  description: string;
  lang: string;
  ogUrl: string;
  ogDescription: string;
  ogImage?: string;
}

const { title, description, lang, ogUrl, ogDescription, ogImage } = Astro.props;
const resolvedOgImage = ogImage || "https://kaoriq.com/og-image.png";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JQT8YQS2GL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JQT8YQS2GL');
    </script>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KaoriQ" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <slot name="head" />
    <style>
      @import "tailwindcss";

      :root,
      [data-theme="dark"] {
        --bg-primary: #0f172a;
        --bg-card: #1e293b;
        --text-primary: #e2e8f0;
        --text-secondary: #cbd5e1;
        --text-label: #94a3b8;
        --text-muted: #64748b;
        --text-separator: #475569;
        --link-color: #c4b5fd;
        --accent-primary: #c4b5fd;
        --accent-warm: #f59e0b;
        --accent-green: #10b981;
      }

      [data-theme="light"] {
        --bg-primary: #faf8f5;
        --bg-card: #ffffff;
        --text-primary: #1e293b;
        --text-secondary: #334155;
        --text-label: #64748b;
        --text-muted: #94a3b8;
        --text-separator: #e2e0db;
        --link-color: #7c3aed;
        --accent-primary: #7c3aed;
        --accent-warm: #d97706;
        --accent-green: #059669;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: var(--bg-primary);
        color: var(--text-primary);
        margin: 0;
        min-height: 100vh;
        transition: background-color 0.2s, color 0.2s;
      }

      a {
        color: var(--link-color);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      .theme-toggle {
        background: none;
        border: 1px solid var(--text-separator);
        color: var(--text-label);
        cursor: pointer;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        font-size: 1rem;
        line-height: 1;
        transition: color 0.2s, border-color 0.2s;
      }
      .theme-toggle:hover {
        color: var(--text-primary);
        border-color: var(--text-label);
      }

      [data-theme="dark"] .icon-sun { display: inline; }
      [data-theme="dark"] .icon-moon { display: none; }
      [data-theme="light"] .icon-sun { display: none; }
      [data-theme="light"] .icon-moon { display: inline; }

      @media (max-width: 640px) {
        main {
          padding: 1.5rem 1rem !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('theme-toggle');
        if (btn) {
          btn.addEventListener('click', function() {
            var current = document.documentElement.getAttribute('data-theme') || 'dark';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
          });
        }
      });
    </script>
  </body>
</html>
