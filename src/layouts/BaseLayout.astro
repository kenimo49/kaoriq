---
import type { Alternate } from '../lib/alternates';

interface Props {
  title: string;
  description: string;
  lang: string;
  ogUrl: string;
  ogDescription: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  alternates?: Alternate[];
  /** デフォルト false。トップページなど SiteEntity を埋め込みたい場合に true */
  isHome?: boolean;
  /** 404 等で canonical を出力したくない場合に true */
  noCanonical?: boolean;
}

const { title, description, lang, ogUrl, ogDescription, ogImage, ogType = 'website', alternates = [], isHome = false, noCanonical = false } = Astro.props;
const SITE_ORIGIN = "https://kaoriq.com";
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${SITE_ORIGIN}${ogImage}`)
  : `${SITE_ORIGIN}/og-image.png`;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "KaoriQ",
  "url": "https://kaoriq.com",
  "logo": "https://kaoriq.com/og-image.png",
  "sameAs": [
    "https://kaoriq.com",
    "https://www.pinterest.com/kaoriqcom/",
  ],
  "parentOrganization": {
    "@type": "Organization",
    "name": "Propel-Lab LLC",
    "url": "https://www.propel-lab.co.jp/",
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "KaoriQ",
  "url": "https://kaoriq.com",
  "description": "Data-driven fragrance recommendations powered by personality science.",
  "inLanguage": ["en", "ja", "fr", "pt", "es"],
  "publisher": { "@id": "https://kaoriq.com#org" },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {!noCanonical && <link rel="canonical" href={ogUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#1A1714" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#FAF7F2" media="(prefers-color-scheme: light)" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JQT8YQS2GL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JQT8YQS2GL');
    </script>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="KaoriQ" />
    {alternates.map(alt => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    {isHome && (
      <>
        <script type="application/ld+json" set:html={JSON.stringify({ ...orgSchema, "@id": "https://kaoriq.com#org" })} />
        <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
      </>
    )}
    <slot name="head" />
    <style>
      @import "tailwindcss";

      :root,
      [data-theme="dark"] {
        --bg-primary: #1A1714;
        --bg-card: #2A2520;
        --text-primary: #E8E0D6;
        --text-secondary: #C4B8A8;
        --text-label: #A89888;
        --text-muted: #7A6E60;
        --text-separator: #3D3630;
        --link-color: #D4A96A;
        --accent-primary: #C4972A;
        --accent-warm: #C07850;
        --accent-green: #7A9A6E;
      }

      [data-theme="light"] {
        --bg-primary: #FAF7F2;
        --bg-card: #FFFFFF;
        --text-primary: #2C1810;
        --text-secondary: #4A3828;
        --text-label: #6B5B4E;
        --text-muted: #9A8A7A;
        --text-separator: #E0D8CE;
        --link-color: #9A7B4F;
        --accent-primary: #B8860B;
        --accent-warm: #C07850;
        --accent-green: #5A7A4E;
      }

      body {
        font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
        background-color: var(--bg-primary);
        color: var(--text-primary);
        margin: 0;
        min-height: 100vh;
        transition: background-color 0.2s, color 0.2s;
      }

      h1, h2, h3 {
        font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
      }

      a {
        color: var(--link-color);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      .theme-toggle {
        background: none;
        border: 1px solid var(--text-separator);
        color: var(--text-label);
        cursor: pointer;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        font-size: 1rem;
        line-height: 1;
        transition: color 0.2s, border-color 0.2s;
      }
      .theme-toggle:hover {
        color: var(--text-primary);
        border-color: var(--text-label);
      }

      [data-theme="dark"] .icon-sun { display: inline; }
      [data-theme="dark"] .icon-moon { display: none; }
      [data-theme="light"] .icon-sun { display: none; }
      [data-theme="light"] .icon-moon { display: inline; }

      @media (max-width: 640px) {
        main {
          padding: 1.5rem 1rem !important;
        }
      }

      footer.site-footer {
        max-width: 720px;
        margin: 4rem auto 0;
        padding: 2rem 2rem 3rem;
        border-top: 1px solid var(--text-separator);
        font-size: 0.8rem;
        color: var(--text-muted);
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        justify-content: space-between;
        align-items: center;
      }
      footer.site-footer a {
        color: var(--text-label);
        text-decoration: none;
      }
      footer.site-footer a:hover {
        color: var(--text-primary);
      }
      footer.site-footer .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
      }
    </style>
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <span>&copy; {new Date().getFullYear()} Propel-Lab LLC</span>
      <div class="footer-links">
        {lang === 'ja' ? (
          <>
            <a href="/ja/about/">運営</a>
            <a href="/ja/privacy/">プライバシー</a>
            <a href="/ja/contact/">お問い合わせ</a>
            <a href="/ja/blog.xml">RSS</a>
            <a href="https://www.pinterest.com/kaoriqcom/" target="_blank" rel="noopener me">Pinterest</a>
          </>
        ) : (
          <>
            <a href="/about/">About</a>
            <a href="/privacy/">Privacy</a>
            <a href="/contact/">Contact</a>
            <a href="/blog.xml">RSS</a>
            <a href="https://www.pinterest.com/kaoriqcom/" target="_blank" rel="noopener me">Pinterest</a>
          </>
        )}
      </div>
    </footer>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('theme-toggle');
        if (btn) {
          btn.addEventListener('click', function() {
            var current = document.documentElement.getAttribute('data-theme') || 'dark';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
          });
        }
      });
    </script>
  </body>
</html>
