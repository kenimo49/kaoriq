---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';

import type { Alternate } from '../lib/alternates';

interface Props {
  title: string;
  description: string;
  lang: string;
  date: Date;
  category?: 'science' | 'guide' | 'story';
  tags: string[];
  canonicalUrl: string;
  ogImage?: string;
  crossPostedTo?: { platform: string; url: string }[];
  alternates?: Alternate[];
}

const { title, description, lang, date, category, tags, canonicalUrl, ogImage, crossPostedTo, alternates = [] } = Astro.props;
const formattedDate = date.toISOString().split('T')[0];
const blogIndexUrl = lang === 'ja' ? '/ja/blog/' : '/blog/';
---

<BaseLayout
  title={`${title} — KaoriQ`}
  description={description}
  lang={lang}
  ogUrl={canonicalUrl}
  ogDescription={description}
  ogImage={ogImage}
>
  <Fragment slot="head">
    {alternates.map(alt => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={date.toISOString()} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": date.toISOString(),
      "author": {
        "@type": "Organization",
        "name": "KaoriQ",
        "url": "https://kaoriq.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "KaoriQ",
      },
      "url": canonicalUrl,
      "mainEntityOfPage": canonicalUrl,
      "keywords": tags.join(', '),
    })} />
    <style>
      .category-badge {
        font-size: 0.7rem;
        padding: 0.1rem 0.45rem;
        border-radius: 4px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }
      .category-science {
        background: rgba(196, 151, 42, 0.15);
        color: var(--accent-primary);
      }
      .category-guide {
        background: rgba(107, 142, 35, 0.15);
        color: #6B8E23;
      }
      .category-story {
        background: rgba(180, 120, 80, 0.15);
        color: #B47850;
      }
      .prose {
        font-size: 1rem;
        line-height: 1.85;
        color: var(--text-secondary);
      }
      .prose h2 {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.6rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--text-separator);
      }
      .prose h3 {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 2rem 0 0.75rem;
      }
      .prose p {
        margin: 0 0 1.25rem;
      }
      .prose a {
        color: var(--link-color);
        text-decoration: underline;
      }
      .prose code {
        background: var(--bg-card);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
      }
      .prose pre,
      .prose :global(pre) {
        background: #1A1714 !important;
        color: #E8E0D6;
        border-radius: 8px;
        padding: 1.25rem !important;
        overflow-x: auto;
        margin: 1.5rem 0;
      }
      .prose pre code,
      .prose :global(pre) code {
        background: none !important;
        color: inherit;
        padding: 0;
      }
      .prose blockquote {
        border-left: 3px solid var(--accent-primary);
        padding-left: 1rem;
        color: var(--text-label);
        margin: 1.5rem 0;
        font-style: italic;
      }
      .prose ul, .prose ol {
        padding-left: 1.5rem;
        margin: 1rem 0;
      }
      .prose li {
        margin: 0.4rem 0;
      }
      .prose img,
      .prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1.5rem 0;
      }
      .prose hr {
        border: none;
        border-top: 1px solid var(--text-separator);
        margin: 2rem 0;
      }
      .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.75rem 0;
        font-size: 0.95rem;
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
      @media (min-width: 768px) {
        .prose table {
          display: table;
          white-space: normal;
        }
      }
      .prose thead {
        background: var(--bg-card);
        border-bottom: 2px solid var(--text-separator);
      }
      .prose th, .prose td {
        border: 1px solid var(--text-separator);
        padding: 0.65rem 1rem;
        text-align: left;
        vertical-align: top;
      }
      .prose th {
        background: var(--bg-card);
        font-weight: 600;
        color: var(--text-primary);
      }
      .prose tbody tr:nth-child(even) {
        background: rgba(196, 151, 42, 0.06);
      }
      .prose tbody tr:hover {
        background: rgba(196, 151, 42, 0.12);
      }
      .prose strong {
        color: var(--text-primary);
        font-weight: 600;
      }
    </style>
  </Fragment>

  <Nav lang={lang} current="blog" />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <article>
      <header style="margin-bottom: 2.5rem;">
        <a href={blogIndexUrl} style="font-size: 0.85rem; color: var(--text-muted); text-decoration: none;">
          &larr; {lang === 'ja' ? 'ブログに戻る' : 'Back to Blog'}
        </a>
        <h1 style="font-size: 2rem; font-weight: 700; margin: 1rem 0 0.75rem; line-height: 1.3;">{title}</h1>
        <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; font-size: 0.85rem; color: var(--text-muted);">
          {category && (
            <span class={`category-badge category-${category}`}>{
              category === 'science' ? (lang === 'ja' ? '科学' : 'Science') :
              category === 'guide' ? (lang === 'ja' ? 'ガイド' : 'Guide') :
              (lang === 'ja' ? 'ストーリー' : 'Story')
            }</span>
          )}
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              {tags.map(tag => (
                <span style="background: var(--bg-card); padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>

      {crossPostedTo && crossPostedTo.length > 0 && (
        <footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--text-separator); font-size: 0.85rem; color: var(--text-muted);">
          <p>
            {lang === 'ja' ? 'この記事は' : 'Also published on '}
            {crossPostedTo.map((cp, i) => (
              <>
                <a href={cp.url} style="color: var(--link-color);">{cp.platform}</a>
                {i < crossPostedTo.length - 1 ? ', ' : ''}
              </>
            ))}
            {lang === 'ja' ? ' にもクロスポストしています。' : '.'}
          </p>
        </footer>
      )}
      <div class="feedback" id="feedback-section">
        <p class="feedback-question">{
          lang === 'ja' ? 'この記事は役に立ちましたか？' :
          lang === 'ko' ? '이 글이 도움이 되었나요?' :
          lang === 'fr' ? 'Cet article vous a-t-il aide ?' :
          lang === 'pt' ? 'Este artigo foi util?' :
          lang === 'es' ? 'Te resulto util este articulo?' :
          'Was this article helpful?'
        }</p>
        <div class="feedback-buttons">
          <button class="feedback-btn" data-reaction="helpful" aria-label="Helpful">
            <span class="feedback-icon">&#9650;</span>
            <span>{lang === 'ja' ? 'はい' : lang === 'ko' ? '네' : lang === 'fr' ? 'Oui' : lang === 'pt' ? 'Sim' : lang === 'es' ? 'Si' : 'Yes'}</span>
          </button>
          <button class="feedback-btn" data-reaction="not_helpful" aria-label="Not helpful">
            <span class="feedback-icon">&#9660;</span>
            <span>{lang === 'ja' ? 'いいえ' : lang === 'ko' ? '아니요' : lang === 'fr' ? 'Non' : lang === 'pt' ? 'Nao' : lang === 'es' ? 'No' : 'No'}</span>
          </button>
        </div>
        <p class="feedback-thanks" style="display: none;">{
          lang === 'ja' ? 'ご回答ありがとうございます' :
          lang === 'ko' ? '의견 감사합니다' :
          lang === 'fr' ? 'Merci pour votre retour' :
          lang === 'pt' ? 'Obrigado pelo seu feedback' :
          lang === 'es' ? 'Gracias por tu opinion' :
          'Thank you for your feedback'
        }</p>
      </div>

    </article>
  </main>
</BaseLayout>

<style>
  .feedback {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--text-separator);
    text-align: center;
  }
  .feedback-question {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .feedback-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  .feedback-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--text-separator);
    border-radius: 20px;
    background: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s;
  }
  .feedback-btn:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }
  .feedback-icon {
    font-size: 0.7rem;
  }
  .feedback-thanks {
    font-size: 0.85rem;
    color: var(--accent-primary);
    margin-top: 0.75rem;
  }
</style>

<script define:vars={{ canonicalUrl, category }}>
  const section = document.getElementById('feedback-section');
  const buttons = section.querySelectorAll('.feedback-btn');
  const thanks = section.querySelector('.feedback-thanks');
  const btnContainer = section.querySelector('.feedback-buttons');

  const slug = canonicalUrl.split('/blog/').pop() || '';

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const reaction = btn.dataset.reaction;

      if (typeof gtag === 'function') {
        gtag('event', 'article_feedback', {
          reaction: reaction,
          article_slug: slug,
          article_category: category || 'unknown',
        });
      }

      btnContainer.style.display = 'none';
      thanks.style.display = '';
    });
  });
</script>
